{
  "$schema": "https://opencode.ai/config.json",
  "name": "lemoria",
  "description": "Sistema Operativo de Memoria y Orquestación para Desarrollo con IA",
  "version": "0.1.0",
  "commands": {
    "lemoria-init": {
      "description": "Initialize Lemoria database and vault",
      "prompt": "Run lemoria init to initialize PostgreSQL tables and create the Obsidian vault directory"
    },
    "lemoria-project": {
      "description": "Create or list Lemoria projects",
      "prompt": "Use lemoria project create <name> to create a new project, or lemoria project list to show all projects"
    },
    "lemoria-flow": {
      "description": "Start an SDD flow from an idea",
      "prompt": "Run lemoria flow start <project-id> '<idea description>' to begin a Spec-Driven Development flow"
    },
    "lemoria-agent": {
      "description": "Register or list Lemoria agents",
      "prompt": "Use lemoria agent register <name> <role> to register an agent, or lemoria agent list to show all agents"
    }
  },
  "agents": {
    "orchestrator": {
      "description": "Agente mayor/orquestador: analiza contexto, revisa PRDs, delega tareas, coordina agentes",
      "mode": "subagent",
      "file": ".opencode/agents/orchestrator.md"
    },
    "backend-agent": {
      "description": "Desarrollo de backend: implementa APIs y lógica Python/SQLAlchemy",
      "mode": "subagent",
      "file": ".opencode/agents/backend-agent.md"
    },
    "db-agent": {
      "description": "Gestión de base de datos: esquemas, migraciones, optimización",
      "mode": "subagent",
      "file": ".opencode/agents/db-agent.md"
    },
    "testing-agent": {
      "description": "Aseguramiento de calidad: tests unitarios e integración",
      "mode": "subagent",
      "file": ".opencode/agents/testing-agent.md"
    },
    "github-agent": {
      "description": "Trazabilidad GitHub: commits, pushes, PRs vinculados a tareas",
      "mode": "subagent",
      "file": ".opencode/agents/github-agent.md"
    },
    "review-agent": {
      "description": "Revisión técnica: alineación con PRD, deuda técnica, trazabilidad",
      "mode": "subagent",
      "file": ".opencode/agents/review-agent.md"
    },
    "documentation-agent": {
      "description": "Documentación técnica: sincroniza memoria con Obsidian vault",
      "mode": "subagent",
      "file": ".opencode/agents/documentation-agent.md"
    }
  },
  "skills": {
    "paths": [".opencode/skills"]
  }
}
